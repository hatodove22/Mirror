# Frontend
VITE_HOST=127.0.0.1
VITE_PORT=5173
VITE_PREVIEW_PORT=4173
VITE_API_PROXY_TARGET=http://127.0.0.1:8004

# API
API_HOST=127.0.0.1
API_PORT=8004
API_RELOAD=true
API_APP_MODULE=backend.app.main:app

# Local model and speech adapters
MIRROR_OLLAMA_URL=http://127.0.0.1:11434
MIRROR_LLM_MODEL=gemma4:e2b
MIRROR_TTS_ENGINE=fallback-wav
MIRROR_AVATAR_ENGINE=stack-chan
MIRROR_AVATAR_CACHE_DIR=data/avatar-cache
MIRROR_DEFAULT_SLIDE_PDF=data/decks/general-meeting/General Meeting.pdf
MIRROR_DEFAULT_SLIDE_JSON=data/decks/general-meeting/General Meeting.json
MIRROR_SPEAK_MAX_CHARS=260
MIRROR_STYLE_BERT_VITS2_URL=http://127.0.0.1:5000
MIRROR_STYLE_BERT_VITS2_MODEL=
MIRROR_STYLE_BERT_VITS2_SPEAKER=
MIRROR_STYLE_BERT_VITS2_STYLE=Neutral
MIRROR_STYLE_BERT_VITS2_STYLE_WEIGHT=1.0
MIRROR_STYLE_BERT_VITS2_LENGTH=1.0
MIRROR_STYLE_BERT_VITS2_REFERENCE_AUDIO=
MIRROR_VOICEVOX_URL=http://127.0.0.1:50021
MIRROR_VOICEVOX_SPEAKER=3
MIRROR_WHISPER_MODEL=base
MIRROR_WHISPER_DEVICE=cpu
MIRROR_WHISPER_COMPUTE_TYPE=int8
MIRROR_FFMPEG_PATH=
MIRROR_ALLOW_CHAT_FALLBACK=true
MIRROR_CORS_ORIGINS=*
MIRROR_REQUEST_TIMEOUT_SECONDS=1200
MIRROR_PRIVACY_LOCAL_ONLY=true

# Shared
APP_ENV=development
LOG_LEVEL=info
