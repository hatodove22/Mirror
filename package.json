{
  "name": "mirror",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,api -c cyan,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm --prefix frontend run dev -- --host 0.0.0.0",
    "dev:api": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-api.ps1",
    "build": "npm --prefix frontend run build",
    "preview": "npm --prefix frontend run preview -- --host 0.0.0.0",
    "check": "npm run typecheck",
    "typecheck": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
